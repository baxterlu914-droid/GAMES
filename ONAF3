import React, { useState, useEffect, useRef, useCallback } from 'react';
import { Ghost, Shield, Zap, Camera, DoorOpen, DoorClosed, AlertTriangle, Skull, Volume2, VolumeX } from 'lucide-react';

// Character Definitions
const MONSTERS = [
  { id: 'liam', name: 'Golden Liam', speed: 5, aggression: 3, description: 'Shines bright before he strikes.' },
  { id: 'chocoman', name: 'Chocoman', speed: 7, aggression: 2, description: 'Leaves sticky trails. Watch the vents.' },
  { id: 'mr_bot', name: 'Dead Mr. Bot', speed: 4, aggression: 4, description: 'Rusted and relentless.' },
  { id: 'mrs_bot', name: 'Evil Mrs. Bot', speed: 4, aggression: 5, description: 'She wants to keep you forever.' },
  { id: 'bobby', name: 'Evil Bobby', speed: 6, aggression: 3, description: 'Lurks in the shadows.' },
  { id: 'green_ham', name: 'Green Ham', speed: 3, aggression: 6, description: 'Slow but hits like a truck.' },
  { id: 'holiday_boy', name: 'Headless Holiday Boy', speed: 8, aggression: 4, description: 'Moves fastest when the lights are off.' },
  { id: 'dlam', name: 'Dlam', speed: 2, aggression: 9, description: 'The ultimate nightmare.' },
];

const CAMERAS = [
  { id: 'cam1', name: 'The Hallway' },
  { id: 'cam2', name: 'The Kitchen' },
  { id: 'cam3', name: 'Supply Closet' },
  { id: 'cam4', name: 'The Playroom' },
  { id: 'cam5', name: 'Ventilation' },
];

const App = () => {
  // Game State
  const [gameState, setGameState] = useState('menu'); // menu, playing, gameover, win
  const [time, setTime] = useState(12); // 12 AM to 6 AM
  const [battery, setBattery] = useState(100);
  const [exposure, setExposure] = useState(0);
  const [currentCam, setCurrentCam] = useState('cam1');
  const [isCamsOpen, setIsCamsOpen] = useState(false);
  const [leftDoorOpen, setLeftDoorOpen] = useState(true);
  const [rightDoorOpen, setRightDoorOpen] = useState(true);
  const [lightOn, setLightOn] = useState(false);
  const [monstersPos, setMonstersPos] = useState({});
  const [jumpscare, setJumpscare] = useState(null);
  const [isMuted, setIsMuted] = useState(false);

  // References for game loop
  const gameLoopRef = useRef(null);
  const lastUpdateRef = useRef(Date.now());

  const startGame = () => {
    setGameState('playing');
    setTime(12);
    setBattery(100);
    setExposure(0);
    setLeftDoorOpen(true);
    setRightDoorOpen(true);
    setJumpscare(null);
    
    // Initial monster positions
    const initialPos = {};
    MONSTERS.forEach(m => initialPos[m.id] = Math.floor(Math.random() * 5) + 1);
    setMonstersPos(initialPos);
  };

  const updateGame = useCallback(() => {
    if (gameState !== 'playing') return;

    const now = Date.now();
    const dt = (now - lastUpdateRef.current) / 1000;
    lastUpdateRef.current = now;

    // Battery Drain
    let drainRate = 0.5;
    if (!leftDoorOpen) drainRate += 2;
    if (!rightDoorOpen) drainRate += 2;
    if (isCamsOpen) drainRate += 1.5;
    if (lightOn) drainRate += 1;
    
    setBattery(prev => {
      const next = prev - (drainRate * dt);
      if (next <= 0) {
        setLeftDoorOpen(true);
        setRightDoorOpen(true);
        setIsCamsOpen(false);
        setLightOn(false);
        return 0;
      }
      return next;
    });

    // Time progression
    if (Math.random() < 0.001) {
      setTime(prev => {
        if (prev === 12) return 1;
        if (prev === 5) {
          setGameState('win');
          return 6;
        }
        return prev + 1;
      });
    }

    // Monster Logic
    setMonstersPos(prev => {
      const next = { ...prev };
      MONSTERS.forEach(monster => {
        // Higher aggression = more likely to move
        if (Math.random() < (monster.aggression * 0.005)) {
          // Move towards office (position 0 is office)
          if (next[monster.id] > 0) {
            next[monster.id] -= 1;
          }
        }
      });
      return next;
    });

    // Danger Check
    const dangers = MONSTERS.filter(m => monstersPos[m.id] === 0);
    if (dangers.length > 0) {
      let isProtected = true;
      // Simple logic: if they are at office, doors must be shut
      // In a real game, some come from left, some from right.
      // For this prototype, we'll check if either door is open.
      if (leftDoorOpen && rightDoorOpen) {
        isProtected = false;
      }

      if (!isProtected) {
        setExposure(prev => {
          const next = prev + (10 * dt);
          if (next >= 100) {
            triggerJumpscare(dangers[0]);
          }
          return next;
        });
      } else {
        setExposure(prev => Math.max(0, prev - (5 * dt)));
      }
    } else {
      setExposure(prev => Math.max(0, prev - (5 * dt)));
    }
  }, [gameState, leftDoorOpen, rightDoorOpen, isCamsOpen, lightOn, monstersPos]);

  useEffect(() => {
    gameLoopRef.current = setInterval(updateGame, 100);
    return () => clearInterval(gameLoopRef.current);
  }, [updateGame]);

  const triggerJumpscare = (monster) => {
    setJumpscare(monster);
    setGameState('gameover');
  };

  const MonsterVisual = ({ monsterId }) => {
    const colors = {
      liam: 'text-yellow-400',
      chocoman: 'text-amber-900',
      mr_bot: 'text-gray-500',
      mrs_bot: 'text-purple-500',
      bobby: 'text-green-500',
      green_ham: 'text-emerald-400',
      holiday_boy: 'text-red-400',
      dlam: 'text-white',
    };
    return (
      <div className={`flex flex-col items-center animate-pulse ${colors[monsterId]}`}>
        <Ghost size={48} />
        <span className="text-xs font-bold uppercase mt-1">{monsterId.replace('_', ' ')}</span>
      </div>
    );
  };

  return (
    <div className="w-full h-screen bg-black text-white font-mono flex flex-col overflow-hidden select-none">
      
      {/* HEADER / HUD */}
      {gameState === 'playing' && (
        <div className="p-4 flex justify-between items-start z-20 pointer-events-none">
          <div>
            <div className="text-3xl font-bold">{time} AM</div>
            <div className="flex items-center gap-2 mt-2">
              <Zap size={20} className={battery < 20 ? 'text-red-500 animate-bounce' : 'text-yellow-400'} />
              <div className="w-32 h-4 bg-gray-800 rounded-full overflow-hidden border border-gray-600">
                <div 
                  className={`h-full transition-all duration-300 ${battery < 20 ? 'bg-red-500' : 'bg-green-500'}`} 
                  style={{ width: `${battery}%` }}
                />
              </div>
              <span className="text-sm font-bold">{Math.floor(battery)}%</span>
            </div>
          </div>
          
          <div className="text-right">
            <div className="text-xs text-gray-400 uppercase tracking-widest">Exposure Level</div>
            <div className="w-48 h-2 bg-gray-900 mt-1 border border-red-900/50">
              <div 
                className="h-full bg-red-600 transition-all"
                style={{ width: `${exposure}%` }}
              />
            </div>
          </div>
        </div>
      )}

      {/* MAIN VIEWPORT */}
      <main className="flex-1 relative flex items-center justify-center">
        {gameState === 'menu' && (
          <div className="text-center space-y-8 max-w-lg p-8 bg-gray-900/50 rounded-xl border border-white/10 backdrop-blur-md">
            <h1 className="text-6xl font-black italic tracking-tighter text-red-600 drop-shadow-lg">
              ONAF 5
            </h1>
            <p className="text-gray-400 text-sm">
              The monsters have returned. Golden Liam and the Chocoman are hunting you. 
              Keep the bots out. Survive until 6 AM.
            </p>
            <button 
              onClick={startGame}
              className="px-12 py-4 bg-white text-black font-black text-xl hover:bg-red-600 hover:text-white transition-colors uppercase tracking-widest rounded-lg"
            >
              Start Night
            </button>
            <div className="grid grid-cols-4 gap-2 mt-4 opacity-50">
              {MONSTERS.map(m => <div key={m.id} className="text-[10px]"><Ghost size={20} className="mx-auto"/>{m.name}</div>)}
            </div>
          </div>
        )}

        {gameState === 'playing' && !isCamsOpen && (
          <div className="w-full h-full relative overflow-hidden bg-neutral-900">
            {/* The Office View */}
            <div className={`absolute inset-0 transition-opacity duration-300 ${lightOn ? 'opacity-30' : 'opacity-10'}`} 
                 style={{ background: 'radial-gradient(circle, #333 0%, #000 100%)' }} />
            
            {/* Left Door */}
            <div className={`absolute left-0 top-0 bottom-0 w-24 bg-zinc-800 border-r-4 border-zinc-700 transition-transform duration-500 flex flex-col items-center justify-center ${leftDoorOpen ? '-translate-x-full' : 'translate-x-0'}`}>
               <div className="w-1 h-full bg-zinc-600" />
            </div>

            {/* Right Door */}
            <div className={`absolute right-0 top-0 bottom-0 w-24 bg-zinc-800 border-l-4 border-zinc-700 transition-transform duration-500 flex flex-col items-center justify-center ${rightDoorOpen ? 'translate-x-full' : 'translate-x-0'}`}>
               <div className="w-1 h-full bg-zinc-600" />
            </div>

            {/* Monsters in Office (Visual Hallucinations) */}
            {exposure > 30 && (
              <div className="absolute inset-0 flex items-center justify-center pointer-events-none opacity-20 animate-pulse">
                <Skull size={200} className="text-red-900" />
              </div>
            )}

            {/* Static Overlay */}
            <div className="absolute inset-0 opacity-5 pointer-events-none bg-[url('https://media.giphy.com/media/oEI9uWUqnW3Ze/giphy.gif')] bg-repeat" />
          </div>
        )}

        {/* CAMERAS OVERLAY */}
        {gameState === 'playing' && isCamsOpen && (
          <div className="absolute inset-0 z-30 bg-black flex flex-col">
            <div className="flex-1 relative bg-zinc-950 flex items-center justify-center overflow-hidden">
              {/* Camera Feed Visuals */}
              <div className="absolute inset-0 opacity-10 bg-[url('https://media.giphy.com/media/oEI9uWUqnW3Ze/giphy.gif')] bg-repeat mix-blend-screen" />
              <div className="absolute top-4 left-4 font-bold text-green-500 animate-pulse flex items-center gap-2">
                <div className="w-3 h-3 bg-red-600 rounded-full" />
                RECORDING - {CAMERAS.find(c => c.id === currentCam)?.name}
              </div>

              {/* Monsters on this specific camera */}
              <div className="flex gap-8 flex-wrap justify-center p-12">
                {MONSTERS.filter(m => `cam${monstersPos[m.id]}` === currentCam).map(m => (
                  <MonsterVisual key={m.id} monsterId={m.id} />
                ))}
                {MONSTERS.filter(m => `cam${monstersPos[m.id]}` === currentCam).length === 0 && (
                    <div className="text-zinc-800 italic">No movement detected...</div>
                )}
              </div>
            </div>

            {/* Cam Selection Bar */}
            <div className="h-24 bg-zinc-900 border-t border-white/20 flex items-center justify-center gap-4 p-4">
              {CAMERAS.map(cam => (
                <button
                  key={cam.id}
                  onClick={() => setCurrentCam(cam.id)}
                  className={`px-4 py-2 text-xs font-bold border transition-colors ${currentCam === cam.id ? 'bg-green-600 border-green-400 text-white' : 'bg-zinc-800 border-zinc-700 text-zinc-400 hover:bg-zinc-700'}`}
                >
                  {cam.id.toUpperCase()}
                </button>
              ))}
            </div>
          </div>
        )}

        {/* GAME OVER */}
        {gameState === 'gameover' && (
          <div className="absolute inset-0 z-50 bg-black flex flex-col items-center justify-center p-8 animate-in fade-in duration-1000">
            <div className="text-red-600 animate-bounce mb-8">
               <Skull size={120} />
            </div>
            <h2 className="text-4xl font-black text-white mb-2 uppercase">You were caught</h2>
            <p className="text-red-400 text-xl font-bold mb-8 italic">"{jumpscare?.description}"</p>
            <button 
              onClick={startGame}
              className="px-10 py-3 bg-red-600 text-white font-bold rounded hover:bg-red-500 transition-transform active:scale-95"
            >
              Try Again
            </button>
          </div>
        )}

        {/* WIN SCREEN */}
        {gameState === 'win' && (
          <div className="absolute inset-0 z-50 bg-white flex flex-col items-center justify-center p-8 animate-in zoom-in duration-500">
            <h2 className="text-6xl font-black text-black mb-4">6:00 AM</h2>
            <p className="text-green-600 text-2xl font-bold mb-12 uppercase tracking-[1em]">Shift Complete</p>
            <button 
              onClick={() => setGameState('menu')}
              className="px-12 py-4 border-4 border-black text-black font-black text-xl hover:bg-black hover:text-white transition-colors"
            >
              Main Menu
            </button>
          </div>
        )}
      </main>

      {/* CONTROLS FOOTER */}
      {gameState === 'playing' && (
        <footer className="bg-zinc-950 p-6 flex justify-between items-center border-t border-white/5">
          <div className="flex gap-4">
            <button 
              onClick={() => setLeftDoorOpen(!leftDoorOpen)}
              disabled={battery <= 0}
              className={`p-4 rounded-lg flex items-center gap-2 transition-all ${leftDoorOpen ? 'bg-zinc-800 text-zinc-400' : 'bg-red-900 text-white border border-red-500 shadow-[0_0_15px_rgba(239,68,68,0.3)]'}`}
            >
              {leftDoorOpen ? <DoorOpen /> : <DoorClosed />}
              <span className="text-xs font-bold uppercase">Left Door</span>
            </button>
            <button 
              onClick={() => setLightOn(!lightOn)}
              disabled={battery <= 0}
              className={`p-4 rounded-lg flex items-center gap-2 transition-all ${!lightOn ? 'bg-zinc-800 text-zinc-400' : 'bg-yellow-900 text-white border border-yellow-500 shadow-[0_0_15px_rgba(234,179,8,0.3)]'}`}
            >
              <Zap size={24} />
              <span className="text-xs font-bold uppercase">Light</span>
            </button>
          </div>

          <button 
            onClick={() => setIsCamsOpen(!isCamsOpen)}
            disabled={battery <= 0}
            className={`px-12 py-4 rounded-xl flex items-center gap-3 font-black text-lg transition-all transform hover:scale-105 active:scale-95 ${isCamsOpen ? 'bg-green-600 text-white shadow-lg' : 'bg-zinc-800 text-zinc-300'}`}
          >
            <Camera />
            {isCamsOpen ? 'CLOSE MONITOR' : 'OPEN MONITOR'}
          </button>

          <div className="flex gap-4">
            <button 
              onClick={() => setIsMuted(!isMuted)}
              className="p-4 rounded-lg bg-zinc-800 text-zinc-400 hover:text-white transition-colors"
            >
              {isMuted ? <VolumeX /> : <Volume2 />}
            </button>
            <button 
              onClick={() => setRightDoorOpen(!rightDoorOpen)}
              disabled={battery <= 0}
              className={`p-4 rounded-lg flex items-center gap-2 transition-all ${rightDoorOpen ? 'bg-zinc-800 text-zinc-400' : 'bg-red-900 text-white border border-red-500 shadow-[0_0_15px_rgba(239,68,68,0.3)]'}`}
            >
              <span className="text-xs font-bold uppercase">Right Door</span>
              {rightDoorOpen ? <DoorOpen /> : <DoorClosed />}
            </button>
          </div>
        </footer>
      )}

      {/* AMBIENCE LAYER */}
      <div className="fixed inset-0 pointer-events-none z-10 opacity-30 bg-gradient-to-b from-transparent to-black" />
    </div>
  );
};

export default App;
